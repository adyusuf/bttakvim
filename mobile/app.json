{
  "expo": {
    "name": "BTTakvim",
    "slug": "bttakvim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bttakvim",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#A3271D",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.btsoft.bttakvim",
      "supportsTablet": true
    },
    "android": {
      "package": "com.btsoft.bttakvim",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#A3271D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#A3271D",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Namaz vakitlerini bulunduğunuz konuma göre göstermek için konumunuza erişiyoruz."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21ce1988-a617-4db5-9468-b481b2468b01"
      }
    },
    "owner": "adyusuf"
  }
}
